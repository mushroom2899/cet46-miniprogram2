page {
    min-height: 100vh; 
    /* 渐变色 */
    background: linear-gradient(to bottom, #F8F5F8, #B2C3D3); 
    background-attachment: fixed;
  }
  .container {
    width: 100vw;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  /* 导航栏 */
  .custom-nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 999;
  }
  .nav-content {
    position: absolute;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 30rpx;
    box-sizing: border-box;
  }
  .nav-left, .nav-right {
    display: flex;
    align-items: center;
    color: #555;
  }
  .nav-right {
    transform: translateY(60rpx); 
    /* margin-top: 60rpx; */
  }
  .nav-icon {
    font-size: 40rpx;
    margin: 0 15rpx;
  }
  .nav-text {
    font-size: 32rpx;
    margin-left: 20rpx;
  }
  
  /* 内容区滚动 */
  .main-content {
    flex: 1;
    padding: 0 30rpx;
    box-sizing: border-box;
  }
  
  /* 单词头部 */
  .word-header {
    padding: 10rpx 10rpx 40rpx;
  }
  .spell {
    font-size: 90rpx;
    font-weight: bold;
    color: #1a1a1a;
  }
  .spell-row {
    display: flex;
    align-items: center; /* 改为居中对齐，让圆点和文字对齐得更好 */
  }
  .spell {
    font-size: 90rpx;
    font-weight: bold;
    color: #1a1a1a;
  }
  
  /* --- 三个进度点和点赞动画样式 --- */
  .study-status {
    display: flex;
    align-items: center;
    margin-left: 20rpx;
  }
  .dots-group {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 40rpx; /* 控制三个点的总体高度 */
  }
  .dot {
    width: 8rpx;
    height: 8rpx;
    border-radius: 50%;
    background-color: #ccc; /* 默认未完成的灰色 */
  }
  .dot-green {
    background-color: #28C76F; /* 完成后的绿色 */
    box-shadow: 0 0 10rpx rgba(40, 199, 111, 0.6); /* 加一点发光效果更精致 */
  }
  .thumb-icon {
    font-size: 44rpx;
    margin-left: 16rpx;
    /* 点赞弹出的 Q 弹动画 */
    animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }
  
  @keyframes popIn {
    0% { transform: scale(0) rotate(-30deg); opacity: 0; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }
  .phonetic-row {
    display: flex;
    align-items: center;
    margin-top: 15rpx;
  }
  .accent-tag {
    background: #d4d3d2;
    color: #3c3b39;
    font-size: 26rpx;
    padding: 0 16rpx;
    border-radius: 30rpx;
    margin-right: 15rpx;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44rpx;
    line-height: 1;
  }
  .phonetic {
    color: #555;
    font-size: 32rpx;
    line-height: 1;
  }
  
  /* 通用卡片样式 */
  .section-card {
    background: rgba(255, 255, 255, 0.75);
    border-radius: 24rpx;
    padding: 36rpx 30rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
  }
  .section-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #444;
  }
  .divider {
    width: 100%;
    height: 2rpx;
    background: rgba(0, 0, 0, 0.05);
    margin: 16rpx 0 20rpx;
  }
  
  /* 核心释义 */
  .core-trans .trans-item {
    margin-bottom: 12rpx;
    font-size: 34rpx;
    display: flex;
    align-items: flex-start;
  }
  .core-trans .pos {
    color: #888;
    margin-right: 16rpx;
    min-width: 60rpx;
    font-style: italic;
    font-size: 28rpx;
    margin-top: 6rpx;
  }
  .core-trans .tran-cn {
    color: #222;
    font-weight: 500;
    flex: 1;
  }
  
  /* 助记法 */
  .memory-box .desc {
    font-size: 30rpx;
    color: #1677FF; /* 采用记忆相关的蓝色调 */
    line-height: 1.6;
  }
  
  /* 短语搭配 */
  .phrase-item {
    margin-bottom: 16rpx;
    display: flex;
    flex-direction: column;
  }
  .p-en {
    font-size: 30rpx;
    color: #222;
    font-weight: 500;
  }
  .p-cn {
    font-size: 26rpx;
    color: #666;
    margin-top: 6rpx;
  }
  
  /* 真题语境 (特殊高亮) */
  .exam-box {
    background: rgba(255, 251, 230, 0.85); /* 淡淡的真题黄底色 */
    border-left: 8rpx solid #FFC107;
  }
  .exam-box .section-title {
    color: #B28200;
  }
  .sentence-item {
    margin-bottom: 30rpx;
    display: flex;
    flex-direction: column;
  }
  .sentence-item:last-child { margin-bottom: 0; }
  .s-en {
    font-size: 30rpx;
    color: #333;
    line-height: 1.5;
    margin-bottom: 10rpx;
  }
  .s-cn {
    font-size: 28rpx;
    color: #777;
  }
  .s-source {
    font-size: 24rpx;
    color: #B28200;
    text-align: right;
    margin-top: 6rpx;
    font-style: italic;
  }
  
  /* 折叠开关 */
  .expand-toggle {
    text-align: center;
    padding: 30rpx 0 20rpx;
    color: #666;
    font-size: 28rpx;
  }
  .expand-panel {
    animation: fadeIn 0.3s ease;
  }
  
  /* 同近义词 & 同根词 */
  .syno-item, .rel-group {
    margin-bottom: 24rpx;
  }
  .s-tran, .r-pos {
    font-size: 28rpx;
    color: #555;
    font-weight: bold;
    margin-bottom: 10rpx;
    display: block;
  }
  .s-hwds {
    display: flex;
    flex-wrap: wrap;
  }
  .s-word {
    background: rgba(0,0,0,0.04);
    padding: 4rpx 16rpx;
    border-radius: 8rpx;
    font-size: 26rpx;
    color: #333;
    margin: 0 12rpx 12rpx 0;
  }
  .r-word-item {
    display: flex;
    flex-direction: column;
    margin-bottom: 12rpx;
  }
  .r-hwd { font-size: 28rpx; color: #333; }
  .r-tran { font-size: 26rpx; color: #777; }
  

/* --- 底部悬浮操作区 --- */
.footer-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40rpx 0 60rpx;
  }

.action-text {
    font-size: 32rpx;
    color: #555;
    font-weight: bold;
    letter-spacing: 2rpx;
  }

.action-line {
    width: 40rpx;
    height: 6rpx;
    margin-top: 10rpx;
    border-radius: 3rpx;
    transition: background-color 0.3s ease; /* 增加平滑过渡动画 */
  }

.line-green {
    background: #28C76F;
  }
