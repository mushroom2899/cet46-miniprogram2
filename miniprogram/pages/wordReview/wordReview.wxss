/* pages/wordReview/wordReview.wxss */
.container {
    height: 100vh;
    width: 100vw;
    display: flex;
    flex-direction: column;
    color: #333;
    overflow: hidden;
    position: relative;
  }
  
  /* 渐变毛玻璃背景 */
  .background-glass {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
    z-index: -1;
  }
  
  /* 顶部 */
  .header {
    width: 100%;
    margin-top: 60rpx;
    padding: 40rpx;
    display: flex;
    align-items: center;
  }

  .progress-text { font-size: 32rpx; color: #666; width: 100rpx; margin-left:60rpx; margin-right:100rpx; }
  .progress-dots { display: flex; gap: 10rpx; }
  .dot { width: 16rpx; height: 16rpx; background: #bbb; border-radius: 50%; }
  .dot.active { background: #FF6B00; }
  .header-icons { width: 100rpx; display: flex; justify-content: flex-end; gap: 30rpx; font-size: 40rpx; }
  
  /* 中部 */
  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-bottom: 200rpx;
    width: 100%;
  }
  
  .input-wrapper {
    position: relative;
    height: 100rpx;
    width: 80%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 40rpx;
  }
  
  .cursor {
    width: 4rpx;
    height: 60rpx;
    background: #f39c12; /* 橙色光标 */
    animation: blink 1s infinite;
  }
  
  .hidden { display: none; }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .real-input {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }
  
  .display-text {
    font-size: 48rpx;
    font-weight: 500;
    letter-spacing: 4rpx;
  }
  
  .translation {
    text-align: center;
    line-height: 1.8;
    font-size: 30rpx;
    color: #444;
  }
  
  /* 底部按钮 */
  .footer {
    width: 100%;
    padding-bottom: 80rpx;
    display: flex;
    justify-content: space-around;
    align-items: center;
  }
  
  .footer.hidden { display: none; } /* 键盘弹出时隐藏底部，防止视觉混乱 */
  
  .circle-btn {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(10px);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 40rpx;
    border: 1rpx solid rgba(255, 255, 255, 0.3);
  }