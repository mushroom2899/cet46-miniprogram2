/* pages/wordReview/wordReview.wxss */
.container {
    height: 100vh;
    width: 100vw;
    display: flex;
    flex-direction: column;
    color: #333;
    overflow: hidden;
    position: relative;
  }
  
  /* 渐变毛玻璃背景 */
  .background-glass {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
    z-index: -1;
  }
  
  /* 顶部 */
  .header {
    width: 100%;
    margin-top: 60rpx;
    padding: 40rpx 0; /* 取消左右 padding，由内部元素控制 */
    display: flex;
    align-items: center;
    position: relative; /* 为文字定位做准备 */
  }

  .progress-text { font-size: 32rpx; color: #666; width: 120rpx; margin-left:60rpx; flex-shrink: 0; z-index: 2; }
  .progress-dots {  flex: 1; display: flex; gap: 10rpx;justify-content: center;gap: 10rpx;margin-right: 180rpx;   }
  .dot { width: 16rpx; height: 16rpx; background: #bbb; border-radius: 50%;  transition: all 0.3s ease; }
  .dot.active { background: #FF6B00; }
  .header-icons { width: 100rpx; display: flex; justify-content: flex-end; gap: 30rpx; font-size: 40rpx; }
  /* --- 进度点拼写正确时的绿色样式 --- */
  .dot.correct-dot {
    background: #018b7b; 
    transform: scale(1.2); /* 微微放大一点点，动效更好 */
    transition: all 0.3s ease;
  }
  
  /* 中部 */
  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-bottom: 200rpx;
    width: 100%;
  }
  
  .input-wrapper {
    position: relative;
    height: 120rpx;
    width: 85%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 40rpx;
  }
  
  .cursor {
    width: 6rpx;
    height: 80rpx;
    background: #FF6B00; /* 橙色光标 */
    animation: blink 1s infinite;
  }
  
  .hidden { display: none; }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .real-input {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }
  
  .display-text {
    font-size: 72rpx;
    font-weight: 500;
    letter-spacing: 6rpx;
  }
  
  .translation {
    text-align: center;
    line-height: 1.8;
    font-size: 34rpx;
    color: #444;
  }
  
  /* 底部按钮 */
  .footer {
    width: 100%;
    padding-bottom: 80rpx;
    display: flex;
    justify-content: space-around;
    align-items: center;
  }
  
  .footer.hidden { display: none; } /* 键盘弹出时隐藏底部，防止视觉混乱 */
  
  .circle-btn {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(10px);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 40rpx;
    border: 1rpx solid rgba(255, 255, 255, 0.3);
  }

/* 音标容器 */
.phonetic-container {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 20rpx;
  /* margin-bottom: 20rpx;  */
  animation: fadeIn 0.3s ease; /* 加个淡入动画更平滑 */
}

/* 音标文字标签样式 */
.phonetic-text {
  font-size: 30rpx;
  color: #444;
  background: rgba(255, 255, 255, 0.4); /* 半透明背景 */
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* --- 拼写正确时的绿色提示文字 --- */
.text-success,.correct-word {
  color: #018b7b !important; 
  transition: color 0.3s ease;
  font-size: 72rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
}

/* 正确答案展示框 */
.correct-answer-box {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx; /* 与下方释义保持间距 */
  min-height: 80rpx;
  animation: fadeIn 0.3s ease; /* 顺滑淡入动画 */
}

