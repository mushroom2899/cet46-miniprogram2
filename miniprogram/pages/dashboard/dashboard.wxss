/* pages/dashboard/dashboard.wxss */
.container {
    background-color: #f4f4f4;
    min-height: 100vh;
    padding: 32rpx 24rpx;
  }
  
  /* 顶部导航 */
  .header {
      display: flex;
      align-items: center; /* 确保返回键在垂直方向居中 */
      padding: 60rpx 30rpx 20rpx 30rpx; 
      position: relative; /* 必须设置，作为标题居中的参考基准 */
      width: 100%;
      box-sizing: border-box;
    }
    
    .custom-back-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10; /* 确保返回键在标题层之上，防止无法点击 */
      margin-left: -20rpx; 
    }
    
    .back-arrow {
      font-size: 40rpx;
      color: #2c3038;
      font-weight: 400;
      line-height: 1; 
    }
    
    .title {
      position: absolute;
      left: 0;
      right: 0;
      text-align: center; /* 文字水平居中 */
      top: 50%;
      transform: translateY(calc(-50% + 20rpx));
      font-size: 36rpx;
      font-weight: bold;
      color: #333;
      z-index: 1; /* 层级低于返回键 */
      pointer-events: none; /* 防止标题层遮挡返回键的点击事件 */
    }
  
  /* 通用 section */
  .section {
    margin-bottom: 32rpx;
    width: 95%;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 36rpx;
    width: 95%;
  }
  .section-title {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
  }
  .change-book-btn {
    background-color: #ff7a45;
    color: #fff;
    padding: 12rpx 24rpx;
    border-radius: 50rpx;
    font-size: 28rpx;
    margin-right: -5%;
  }
  
  /* 正在学习模块 */
  .learning-section {
    margin: 42rpx 32rpx 32rpx 32rpx;
    border-radius: 24rpx;
  }
  .main-learning-card {
      background-color: #ffffff;
      border-radius: 24rpx;
      padding: 30rpx;
      box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
    }
  
    /* 第一行：书本与添加按钮 */
    .book-row {
      display: flex;
      align-items: flex-start;
      position: relative;
      margin-bottom: 30rpx;
    }
  .book-card {
    display: flex;
    align-items: flex-start;
    gap: 24rpx;
    margin-bottom: 32rpx;
  }
