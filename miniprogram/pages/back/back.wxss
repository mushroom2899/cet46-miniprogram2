/* 1. 修改头部容器：取消原本的 padding，改用 space-between 逻辑 */
.header {
  width: 100%;
  margin-top: 60rpx;
  padding: 40rpx 0; /* 取消左右 padding，由内部元素控制 */
  display: flex;
  align-items: center;
  position: relative; /* 为文字定位做准备 */
}

/* 2. 进度文字：保持左侧间距不变 */
.progress-text {
  font-size: 32rpx;
  color: #666;
  width: 120rpx;      /* 稍微加宽一点防止数字跳动 */
  margin-left: 60rpx; /* 保持你要求的左侧位置不改变 */
  flex-shrink: 0;     /* 防止被挤压 */
  z-index: 2;
}

/* 3. 进度点容器：核心修改 */
.progress-dots {
  flex: 1;            /* 占据除去文字后的所有剩余空间 */
  display: flex;
  justify-content: center; /* 在剩余空间内水平居中 */
  gap: 10rpx;
  margin-right: 180rpx;    /* 【关键点】右侧也给一个边距，抵消掉左侧文字的宽度，实现真正的视觉居中 */
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #bbb;
  border-radius: 50%;
  transition: all 0.3s ease;
}