<view class="header">
    <view class="progress-text">{{currentIndex + 1}}/{{targetReviewCount}}</view>
    <view class="progress-dots">
      <view wx:for="{{targetReviewCount}}" wx:key="index" 
          class="dot {{index < currentIndex ? 'active' : ''}} {{index === currentIndex && isCorrect ? 'correct-dot' : ''}}"></view>
    </view>
  </view>

  <view class="footer {{keyboardHeight > 0 ? 'hidden' : ''}}">
    <view class="action-btn circle-btn" bindtap="goBack"><text>×</text></view>
    <view class="action-btn circle-btn light-btn" bindtap="playHint"><text>💡</text></view>
    <view class="action-btn circle-btn {{isCorrect ? 'btn-correct' : ''}}" bindtap="checkAnswer">
      <text>{{isCorrect ? '→' : '✓'}}</text>
    </view>
  </view>