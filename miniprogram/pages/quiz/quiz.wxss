.tab-item {
    color: #9094a0;
    font-size: 30rpx;
    position: relative;
    padding-bottom: 10rpx;
  }
  
  .tab-item.active {
    color: #2c3038;
    font-weight: bold;
    font-size: 34rpx;
  }
  
  .tab-item.active::after {
    content: "";
    position: absolute;
    bottom: -4rpx;
    left: 50%;
    transform: translateX(-50%);
    width: 32rpx;
    height: 6rpx;
    background: #ff8c00;
    border-radius: 4rpx;
  }