/* pages/bookSelect/bookSelect.wxss */

  /* 自定义导航栏样式 */
.custom-nav {
    display: flex;
    align-items: center;
    padding: 100rpx 30rpx 20rpx 30rpx; /* padding-top 用于避开手机状态栏 */
    position: relative;
    width: 100%;
    box-sizing: border-box;
  }
  
  /* 返回按钮 */
  .custom-back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10; /* 层级调高，确保能被点击 */
    padding: 10rpx 20rpx 10rpx 0; /* 增加一点点击热区 */
  }
  
  .back-arrow {
    font-size: 40rpx;
    color: #333333;
    font-weight: 400;
    line-height: 1;
  }
  
  /* 页面标题 */
  .large-title {
    position: absolute;
    left: 0;
    right: 0;
    text-align: center; /* 绝对定位实现水平居中 */
    bottom: 25rpx; /* 根据实际视觉效果与返回箭头对齐 */
    font-size: 34rpx;
    font-weight: bold;
    color: #333333;
    pointer-events: none; /* 防止标题宽度遮挡左侧返回键的点击 */
    z-index: 1;
  }
  
.container {
    background-color: #fff;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  /* 搜索栏 */
  .search-bar {
    margin: 15rpx 30rpx;
    background-color: #f5f5f5;
    height: 5%;
    width: 85%;
    border-radius: 20rpx;
    display: flex;
    align-items: center;
    padding: 0 30rpx;
    flex-shrink: 0;
  }
  .search-placeholder { color: #999; font-size: 36rpx; }
  
  /* 主分类 */
  .main-tabs {
    white-space: nowrap;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #eee;
  }
  .tab-item {
    display: inline-block;
    padding: 0 30rpx;
    font-size: 32rpx;
    color: #666;
    position: relative;
  }
  .tab-item.active {
    color: #ff6600;
    font-weight: bold;
  }

  /* 词书列表 */
  .book-list { 
    flex: 1; 
    padding: 0 30rpx;
    background-color: #fff;
   }
  .book-item {
    display: flex;
    padding: 30rpx;
    border-bottom: 1rpx solid #f9f9f9;
  }
  .book-cover-wrapper {
    position: relative;
    width: 140rpx;
    height: 190rpx;
    margin-right: 30rpx;
  }
  .book-cover {
    width: 100%;
    height: 100%;
    border-radius: 8rpx;
    background-color: #eee;
  }
  
  .book-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .book-title { font-size: 32rpx; color: #333; font-weight: 500; margin-bottom: 15rpx; }
  .book-desc { font-size: 26rpx; color: #999; margin-bottom: 15rpx; }
  .book-count { font-size: 26rpx; color: #bbb; }