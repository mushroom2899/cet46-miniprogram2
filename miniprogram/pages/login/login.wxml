<!--pages/login/login.wxml-->
<view class="container">

  <!-- 标题区域 -->
  <view class="title-area">
    <view class="logo">
      <text class="logo-top">不</text>
      <text class="logo-bottom">背</text>
    </view>
    <view class="slogan">轻松过级来不背</view>
  </view>

  <!-- 登录按钮区域 -->
  <view class="btn-area">
    <!-- 微信登录 -->
    <button class="btn" bindtap="onWechatLogin">
      <image class="btn-icon" src="/images/wechat-icon.png"></image>
      <text>微信登录</text>
    </button>
  </view>

  <!-- 协议勾选 -->
<view class="agreement-area">
  <checkbox-group bindchange="onAgreeChange">
    <checkbox class="agreement-checkbox" 
              checked="{{isAgree}}" 
              value="agree" /> 
  </checkbox-group>
  <text class="agreement-text">我已阅读并同意</text>
  <text class="agreement-text" style="color: #ff8c78;" catchtap="goTerms">《服务条款》</text>
  <text class="agreement-text">和</text>
  <text class="agreement-text" style="color: #ff8c78;" catchtap="goPrivacy">《隐私协议》</text>
</view>
</view>