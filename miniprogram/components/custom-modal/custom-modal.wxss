/* components/custom-modal/custom-modal.wxss */
/* 黑色半透明遮罩 */
.modal-mask {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    display: flex;
    align-items: flex-end; 
    animation: fadeIn 0.2s ease-out;
  }
  
  /* 弹窗主体白框 */
  .modal-content {
    width: 100vw; /* 占满屏幕宽度 */
    background: #FFFFFF;
    border-radius: 32rpx 32rpx 0 0; /* 关键：只有左上、右上大圆角 */
    padding-bottom: env(safe-area-inset-bottom); /*  关键：防全面屏底部黑条遮挡 */
    display: flex;
    flex-direction: column;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1); /* 顺滑的底部推上动画 */
  }
  
  /* 顶部操作栏 */
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 110rpx;
    padding: 0 40rpx;
    border-bottom: 1rpx solid #F5F5F5;
  }
  
  .modal-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #333333;
  }
  
  .header-btn {
    font-size: 30rpx;
    padding: 20rpx 0;
  }
  
  .btn-cancel {
    color: #999999;
  }
  
  .btn-confirm {
    color: #FF6B00;
    font-weight: 500;
  }
  
  /* 内容区 */
  .modal-body {
    padding: 10rpx 40rpx 40rpx 40rpx;
    max-height: 60vh;
    box-sizing: border-box;
  }
  
  /* 动画定义 */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }